{
  "manifest_version": 3,
  "name": "GoodHR 4",
  "version": "4.1.0",
  "description": "哦买噶，你太棒了！现在插件已经安装成功了。准备起飞吧",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["activeTab", "tabs", "storage", "downloads", "sidePanel"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "*://*.zhipin.com/*",
    "*://*.lagou.com/*",
    "*://*.zhaopin.com/*",
    "*://*.liepin.com/*",
    "*://*.58.com/*",
    "*://employer.58.com/*",
    "*://h.liepin.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_title": "GoodHR 4 Pixel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
