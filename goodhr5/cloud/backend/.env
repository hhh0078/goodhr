# GoodHR 5 云端后端完整配置
# 复制为 .env 修改值

# 服务监听地址
GOODHR_CLOUD_ADDR=:8080

# PostgreSQL连接(不配用内存)
GOODHR_PG_DSN=

# Redis地址(不配用内存)
GOODHR_REDIS_ADDR=
GOODHR_REDIS_PASSWORD=
GOODHR_REDIS_DB=0

# SMTP邮件(不配则开发模式)
GOODHR_SMTP_HOST=
GOODHR_SMTP_PORT=465
GOODHR_SMTP_USERNAME=
GOODHR_SMTP_PASSWORD=
GOODHR_SMTP_FROM=

# Cookie加密主密钥(openssl rand -hex 32)
GOODHR_ENCRYPTION_KEY=
