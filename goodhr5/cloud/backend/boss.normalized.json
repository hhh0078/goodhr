{
  "id": "boss",
  "name": "Boss直聘",
  "open": true,
  "domain": "zhipin.com",
  "description": "Boss直聘平台规整版配置草案，用于把页面、初始化动作、岗位切换、候选人列表和候选人详情按业务含义分组。",
  "schema_version": "2026-07-13.normalized-draft",
  "legacy_source": "goodhr5/cloud/backend/boss.json",
  "runtime_notes": {
    "current_status": "草案文件，当前运行代码仍读取 boss.json。",
    "selector_protocol": "每个选择器对象都保留 id、title、description、parent_selectors、target_selectors，后续可转换成旧版 parent_classes、target_classes。",
    "code_mapping": {
      "entry_page": "local-agent-go/internal/platforms/boss/navigation.go platformEntryPage/pageMatchesEntry",
      "init_actions": "local-agent-go/internal/platforms/boss/runtime.go PrepareEntryPage 当前有硬编码 .boss-dialog__body 和 .boss-dialog__footer .btn",
      "job_switch": "local-agent-go/internal/platforms/boss/runtime.go CurrentPositionName/SelectPosition",
      "candidate_list": "local-agent-go/worker-node/src/index.js bossRules/extractBossCandidates/scrollBossCandidates/greetBossCandidate",
      "candidate_detail": "local-agent-go/worker-node/src/index.js extractBossCandidateDetail/screenshotDetailContainer"
    }
  },
  "pages": {
    "public": [
      {
        "id": "boss_login",
        "title": "Boss登录页",
        "description": "未登录时进入的 Boss 登录页面。",
        "url": "https://login.zhipin.com",
        "match": "prefix",
        "legacy_path": "public.pages[0]"
      },
      {
        "id": "boss_user_login",
        "title": "Boss用户登录页",
        "description": "Boss 用户登录相关页面。",
        "url": "https://www.zhipin.com/web/user/",
        "match": "prefix",
        "legacy_path": "public.pages[1]"
      }
    ],
    "auth_required": [
      {
        "id": "chat_home",
        "title": "登录后通用路由",
        "description": "登录后聊天工作台通用地址，用于判断已经处于 Boss 登录态页面。",
        "url": "https://www.zhipin.com/web/chat",
        "match": "contains",
        "entry": false,
        "legacy_path": "auth.pages[0]"
      },
      {
        "id": "recommend_candidates",
        "title": "推荐牛人",
        "description": "任务入口页面，进入后开始确认岗位和读取推荐候选人。",
        "url": "https://www.zhipin.com/web/chat/recommend",
        "match": "prefix",
        "entry": true,
        "legacy_path": "auth.pages[1]"
      }
    ],
    "auth_rules": {
      "entry_url": "https://www.zhipin.com/web/chat/recommend",
      "login_url_prefixes": [
        "https://login.zhipin.com",
        "https://www.zhipin.com/web/user/"
      ],
      "logged_in_url_prefix": "https://www.zhipin.com/web/chat",
      "logged_in_url_contains": ["www.zhipin.com/web/chat"],
      "legacy_path": "auth"
    }
  },
  "init_actions": [
    {
      "id": "entry_confirm_dialog",
      "title": "公告弹窗",
      "description": "页面打开后可能出现的确认弹框，当前 Boss runtime 会检测弹框正文，存在时点击底部按钮。",
      "trigger": {
        "type": "element_exists",
        "selector": {
          "id": "entry_confirm_dialog_body",
          "title": "确认弹框正文",
          "description": "用于判断 Boss 入口页是否出现确认类弹框。",
          "parent_selectors": [],
          "target_selectors": [".boss-dialog__body"],
          "legacy_path": "runtime hardcode PrepareEntryPage.dialog"
        }
      },
      "action": {
        "type": "click",
        "selector": {
          "id": "entry_confirm_dialog_button",
          "title": "确认弹框按钮",
          "description": "用于关闭或确认 Boss 入口页弹框。",
          "parent_selectors": [".boss-dialog__footer"],
          "target_selectors": [".btn"],
          "legacy_path": "runtime hardcode PrepareEntryPage.button"
        }
      }
    },
    {
      "id": "resume_custom_close",
      "title": "简历弹层关闭",
      "description": "候选人详情弹层关闭按钮，当前也作为 detail.closeBtn 使用。",
      "trigger": {
        "type": "element_exists",
        "selector": {
          "id": "resume_popup_close",
          "title": "详情关闭按钮",
          "description": "用于关闭 Boss 候选人详情弹层。",
          "parent_selectors": [],
          "target_selectors": [".boss-popup__close", ".resume-custom-close"],
          "legacy_path": "detail.closeBtn"
        }
      },
      "action": {
        "type": "click",
        "selector_ref": "resume_popup_close"
      }
    }
  ],
  "job_switch": {
    "description": "Boss 岗位切换区域。Go runtime 会先读取当前岗位，若与任务岗位不一致，则点击岗位下拉并从列表中选择目标岗位。",
