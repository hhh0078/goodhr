# GoodHR 自动化工具配置文件示例
# 复制为 .env 后填入实际值

# AI 平台配置（ai.58it.cn）
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-5.1-chat
AI_BASE_URL=https://ai.58it.cn/v1/chat/completions

# CloakBrowser 隐身浏览器二进制路径（跳过自动下载）
CLOAKBROWSER_BINARY_PATH=./data/browser/Chromium.app/Contents/MacOS/Chromium

# 浏览器配置
BROWSER_HEADLESS=false
BROWSER_HUMANIZE=true
BROWSER_HUMAN_PRESET=default

# 代理配置（可选）
# PROXY=http://user:pass@proxy:8084
# PROXY_SOCKS5=socks5://user:pass@proxy:1080

# Web 服务配置
WEB_HOST=127.0.0.1
WEB_PORT=8788

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/goodhr.db
