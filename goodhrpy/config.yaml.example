# GoodHR 自动化工具配置文件示例
# 复制为 config.yaml 后填入实际值

ai:
  api_key: "your_api_key_here"
  model: "gpt-5.1-chat"
  base_url: "https://ai.58it.cn/v1/chat/completions"
  click_prompt: ""
  contact_prompt: ""
  temperature: 0.3

browser:
  headless: false
  humanize: true
  human_preset: "default"
  proxy: ""

task:
  match_limit: 60
  scroll_delay_min: 3
  scroll_delay_max: 8
  click_frequency: 7

web:
  host: "127.0.0.1"
  port: 8788

database:
  url: "sqlite+aiosqlite:///./data/goodhr.db"
